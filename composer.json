{
    "name": "marketing/browser",
    "description": "Browser MVP: plataforma web independiente para b\u00fasqueda, correo, privacidad y marketing digital.",
    "type": "project",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.3",
        "vlucas/phpdotenv": "^5.6"
